dist/
build/
*.min.js
*.min.css

# Sass cache (if using Sass)
.sass-cache/
*.css.map
*.sass.map
*.scss.map

# ============================================
# SECURITY & SENSITIVE FILES
# ============================================
# Don't commit sensitive data
*.key
*.pem
*.p12
*.pfx
.env
.env.*
!.env.example
secrets.json
config.local.js
.htpasswd

# SSL certificates
*.crt
*.cer
*.der

# ============================================
# TESTING
# ============================================
test-results/
coverage/
*.test.js.snap

# ============================================
# DOCUMENTATION (keep these for now)
# ============================================
# Uncomment if you don't want SEO docs in repo
# SEO-GUIDE.md
# SEO-IMPLEMENTATION-COMPLETE.md

# ============================================
# DRAFTS / WORK IN PROGRESS
# ============================================
# Uncomment to exclude draft content
# blog/content/drafts/
# **/draft-*
# **/*-draft.*
# **/*-wip.*

# ============================================
# ANALYTICS / STATS
# ============================================
# Uncomment if you generate local analytics
# stats/
# analytics/
# reports/

# ============================================
# CUSTOM EXCLUSIONS
# ============================================
# Add any project-specific files to ignore below
# Example: local development scripts
# dev-server.py
# local-*.html
# test-*.md




SEO-GUIDE.md  
SEO-IMPLEMENTATION-COMPLETE.md
